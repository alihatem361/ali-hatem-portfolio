# ─── Sanity ───────────────────────────────────────────────────────────────────
# Get these from https://sanity.io/manage → your project → Settings → API

# Required: your Sanity project ID (shown in the URL: sanity.io/manage/project/<projectId>)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here

# Required: dataset name (default is "production")
NEXT_PUBLIC_SANITY_DATASET=production

# Optional: only needed when your dataset is set to "private"
# Create a token at sanity.io/manage → API → Tokens → Add API token (Viewer role)
SANITY_API_READ_TOKEN=

# Required for the seed script (npm run seed)
# Create a token at sanity.io/manage → API → Tokens → Add API token (Editor role or higher)
SANITY_API_WRITE_TOKEN=your_write_token_here

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
# This key is SERVER-ONLY — never prefix it with NEXT_PUBLIC_
GEMINI_API_KEY=your_gemini_api_key_here
